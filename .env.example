# Titan Email SMTP — copy to .env.local and fill in real values
MAIL_MAILER=smtp
MAIL_HOST=smtp.titan.email
MAIL_PORT=465
MAIL_USERNAME=your-email@printx.ae
MAIL_PASSWORD=your-mailbox-password
MAIL_ENCRYPTION=ssl
MAIL_TO=your-email@printx.ae

# Public site URL for sitemap, robots, and canonical metadata
NEXT_PUBLIC_SITE_URL=https://printxdxb.ae
